# ============================================================
# SponsorFlow.io — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# -----------------------------------------------------------
# 🤖 AI / LLM  (Kimi / Moonshot AI)
# -----------------------------------------------------------
# Primary: Moonshot AI API key (https://platform.moonshot.cn)
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Fallback: OpenAI-compatible key (used if MOONSHOT_API_KEY is not set)
OPENAI_API_KEY=your_openai_api_key_here

# Moonshot base URL (default: https://api.moonshot.cn/v1)
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Moonshot model to use (default: moonshot-v1-8k)
KIMI_MODEL=moonshot-v1-8k

# -----------------------------------------------------------
# 📧 IMAP  (Newsletter email ingestion)
# -----------------------------------------------------------
# IMAP server hostname (default: imap.gmail.com)
IMAP_SERVER=imap.gmail.com

# IMAP server port (default: 993 for SSL)
IMAP_PORT=993

# Email address to read newsletters from
IMAP_EMAIL=your_email@gmail.com

# Email password or app-specific password
IMAP_PASSWORD=your_app_password_here

# -----------------------------------------------------------
# 🗄️ Database  (Supabase / PostgreSQL)
# -----------------------------------------------------------
# Supabase PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
SUPABASE_DB_URL=postgresql://postgres:your_password@db.your_project.supabase.co:5432/postgres

# Alternative generic database URL (used if SUPABASE_DB_URL is not set)
# Falls back to local SQLite (sponsorflow.db) when neither is configured
DATABASE_URL=
